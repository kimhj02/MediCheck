# MediCheck Expo - API 서버 주소
# iOS 시뮬레이터: localhost 사용
# Android 에뮬레이터: 10.0.2.2 (호스트 머신)
# 실제 기기 테스트: 개발 PC IP (예: 192.168.0.10)
EXPO_PUBLIC_API_URL=http://localhost:8080/api

# 카카오 로그인(REST API 키). 비우면 상위 frontend/.env 의 VITE_KAKAO_REST_API_KEY 를 app.config.js 가 읽습니다.
# EXPO_PUBLIC_KAKAO_REST_API_KEY=
#
# Expo Go: 카카오 redirect_uri 는 보통 https(또는 auth.expo.io) 입니다.
# EAS/스토어·개발 빌드(Standalone·Bare)는 앱이 medicheck://app/oauth/kakao/callback 을 씁니다. 카카오·백엔드에 동일 문자열 등록.
# EXPO_PUBLIC_API_URL 이 https://www.example.com/api 인데 실제 콜백이 https://example.com/oauth/... 인 경우
# (또는 주소창이 apex 인데 API 만 www 인 경우) iOS 17.4+ 인증 세션이 끝나지 않아 웹 SPA 만 보일 수 있습니다.
# 아래에 카카오 디벨로퍼스·백엔드에 등록한 콜백 **호스트와 동일한** origin 을 넣으세요(경로 없이).
# EXPO_PUBLIC_KAKAO_OAUTH_REDIRECT_ORIGIN=https://example.com
#
# API 가 공개 https 가 아니면 auth.expo.io 프록시 등을 쓰며, 그때는 카카오·백엔드에 해당 redirect URI 를 등록하세요.

# 카카오맵 JavaScript 키 (내 주변 지도 WebView)
# 비우면 상위 `frontend/.env`의 VITE_KAKAO_APP_KEY(웹 지도와 동일 키)를 자동 사용합니다.
# 카카오 디벨로퍼스 → 앱 → 플랫폼 → Web → 사이트 도메인: https://localhost
EXPO_PUBLIC_KAKAO_MAP_APP_KEY=

# WebView origin (카카오 콘솔 Web 사이트 도메인과 동일해야 지도 로드됨)
# EXPO_PUBLIC_KAKAO_MAP_BASE_URL=https://localhost
