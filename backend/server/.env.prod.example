# Spring Boot prod profile (required)
SPRING_DATASOURCE_URL=jdbc:mysql://<rds-endpoint>:3306/medi_check?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# Security (required in production)
JWT_SECRET=<at-least-32-bytes-secret>
ADMIN_SYNC_KEY=<admin-sync-key>

# External APIs
HIRA_SERVICE_KEY=<hira-service-key>
KAKAO_MOBILITY_REST_API_KEY=<kakao-mobility-rest-key>
KAKAO_OAUTH_REST_API_KEY=<kakao-oauth-rest-key>
KAKAO_OAUTH_CLIENT_SECRET=<kakao-oauth-client-secret>
KAKAO_OAUTH_ALLOWED_REDIRECT_URIS=https://<your-frontend-domain>/oauth/kakao/callback

# Frontend domain(s) allowed by CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://<your-frontend-domain>
