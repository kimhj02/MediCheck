# MediCheck backend — 환경변수 예시 (이 파일만 복사해 사용, 실제 값은 커밋하지 마세요)
#
# 사용법:
#   cp .env.example .env
#   편집 후, 셸에서 export:
#     set -a && source .env && set +a
#   또는 한 줄:
#     export DB_PASSWORD='your-mysql-password'
#
# Spring Boot는 기본적으로 .env를 읽지 않습니다. IDE Run 설정·터미널·Docker·CI 시크릿으로
# 동일한 이름의 환경변수를 넣어 주세요.

# 필수: MySQL (application.yaml → spring.datasource.password)
DB_PASSWORD=

# default 프로필: JWT_SECRET 필수. UTF-8 기준 최소 32바이트 이상이어야 한다.
# JWT_SECRET=9fK2mQ7xLp4vNz8tRb1cYw6hJd3sUa0B
# ADMIN_SYNC_KEY=
# HIRA_SERVICE_KEY=
# KAKAO_MOBILITY_REST_API_KEY=
# KAKAO_OAUTH_REST_API_KEY=
# KAKAO_OAUTH_CLIENT_SECRET=

# prod + 브라우저 SPA: 허용 출처(쉼표). 예: https://d1234567890.cloudfront.net
# CORS_ALLOWED_ORIGINS=

# prod 필수 (Spring 표준 JDBC URL·계정). 예: jdbc:mysql://xxx.rds.amazonaws.com:3306/medi_check?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_USERNAME=
